# Root directory for all datasets on this machine.
# Defaults to <project-root>/data
DATA_DIR=/path/to/data

# Root directory for all experiment outputs on this machine.
# Defaults to <project-root>/experiments
EXPERIMENTS_DIR=/path/to/experiments


# ---- Weights & Biases ----
# Mode: 'online' (sync live), 'offline' (log locally, sync later), or 'disabled'.
WANDB_MODE=online
WANDB_API_KEY=your-wandb-api-key


# ---- Hugging Face ----
# Where HF caches models/datasets.
HF_HOME=~/.cache/huggingface

# Set these to 1 on machines without internet and use the local cache only.
# Leave unset (or 0) for normal dev.
HF_DATASETS_OFFLINE=
HF_HUB_OFFLINE=
TRANSFORMERS_OFFLINE=